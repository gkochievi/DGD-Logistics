# PostgreSQL
POSTGRES_DB=transport_db
POSTGRES_USER=transport_user
POSTGRES_PASSWORD=transport_secret_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# Frontend
REACT_APP_API_URL=http://localhost/api
# Notification poll interval in milliseconds. Leave unset or 0 to use default (10000).
REACT_APP_NOTIFICATION_POLL_MS=15000

# DigitalOcean Spaces (S3-compatible) — set USE_SPACES=True to upload media + static to Spaces
# Leave USE_SPACES=False (or unset) to keep local filesystem storage.
USE_SPACES=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
# Spaces region slug (e.g. nyc3, ams3, fra1, sgp1, sfo3, syd1)
AWS_S3_REGION_NAME=nyc3
# Defaults to https://<region>.digitaloceanspaces.com — override only for non-DO S3 endpoints
AWS_S3_ENDPOINT_URL=
# Optional CDN/CNAME host (e.g. <bucket>.<region>.cdn.digitaloceanspaces.com or cdn.example.com)
AWS_S3_CUSTOM_DOMAIN=
# Path prefixes inside the bucket
AWS_LOCATION_STATIC=static
AWS_LOCATION_MEDIA=media
